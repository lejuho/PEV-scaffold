# Copy to config/hermes.env and fill local values.
HERMES_ROOT=/home/pi/cairn
HERMES_LOG_DIR=/home/pi/cairn/logs

HERMES_TELEGRAM_TOKEN=
HERMES_CHAT_ID=

# Stable tmux targets created by pev-tmux.service.
HERMES_CLAUDE_PANE=cairn-claude:0
HERMES_CODEX_PANE=codex-hermes:0

HERMES_POLL_SECONDS=5
HERMES_SUBMIT_KEY=C-m
HERMES_SUBMIT_DELAY=0.35

# Agent startup defaults used by scripts/ensure-pev-tmux.sh.
PEV_CLAUDE_SESSION=cairn-claude
PEV_CODEX_SESSION=codex-hermes
PEV_CLAUDE_BIN=/home/pi/.local/bin/claude
PEV_CODEX_BIN=/mnt/data/pi_storage/.npm-global/bin/codex
PEV_CLAUDE_ARGS=--continue --dangerously-skip-permissions
PEV_CODEX_ARGS=--no-alt-screen --dangerously-bypass-approvals-and-sandbox

# Dashboard bind. Use 127.0.0.1 for local-only or a Tailscale/VPN IP.
PEV_DASHBOARD_HOST=127.0.0.1
PEV_DASHBOARD_PORT=8765
